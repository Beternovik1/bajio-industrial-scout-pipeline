# .env.example
DATABASE_URL=postgresql://user:password@host:5432/db
WORKER_NAME=Edgar

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Execution mode: cloud_extraction | local_enrichment_only | local_full
EXECUTION_MODE=local_full

# New scrapers config
COMPUTRABAJO_ENABLED=true
COMPUTRABAJO_MAX_RESULTS=100
COMPUTRABAJO_COUNTRIES=MX
COMPUTRABAJO_REMOTE=false
OCC_ENABLED=true
OCC_MAX_RESULTS=100
OCC_REMOTE=false

# Enrichment config
DAILY_ENRICHMENT_LIMIT=100
ENRICHMENT_BATCH_SIZE=20
ENRICHMENT_COOLDOWN=60
